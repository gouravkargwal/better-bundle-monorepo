# ===========================================
# BetterBundle Development Environment
# ===========================================
# Copy this to .env.dev and update with your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug
HOT_RELOAD=true

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BROKERS=kafka_b:9092
KAFKA_BOOTSTRAP_SERVERS=kafka_b:9092

# ===========================================
# TFRS + VERTEX AI (replaces Gorse)
# ===========================================
TFRS_MODEL_PATH=models/tfrs
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
# Set to true + use a Vertex AI Express Mode key to switch backends later
GOOGLE_GENAI_USE_VERTEXAI=false
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004
VERTEX_AI_GENERATIVE_MODEL=gemini-2.0-flash-001

# ===========================================
# SHOPIFY APP CONFIGURATION (Development)
# ===========================================
SHOPIFY_API_KEY=your_dev_shopify_api_key
SHOPIFY_API_SECRET=your_dev_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders
SHOPIFY_APP_URL=https://your-ngrok-url.ngrok.io
SHOPIFY_APP_SESSION_SECRET=dev_session_secret_123
SHOPIFY_APP_HANDLE=better-bundle-dev

# ===========================================
# MONITORING & LOGGING
# ===========================================
OPENOBSERVE_URL=http://openobserve:5080
OPENOBSERVE_EMAIL=admin@betterbundle.com
OPENOBSERVE_PASSWORD=BetterBundle@Dev2024
OPENOBSERVE_ORG_ID=default

# Distributed Tracing (OpenTelemetry -> OpenObserve)
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5080
OTEL_SERVICE_NAME=betterbundle-dev

# ===========================================
# SECURITY & ENCRYPTION (Development)
# ===========================================
JWT_SECRET=dev_jwt_secret_123
ENCRYPTION_KEY=dev_encryption_key_123
