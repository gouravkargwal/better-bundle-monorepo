# ===========================================
# BetterBundle Development Environment
# ===========================================
# Copy this to .env.dev and update with your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug
HOT_RELOAD=true

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=kafka_b:9092

# ===========================================
# GORSE RECOMMENDATION ENGINE
# ===========================================
GORSE_BASE_URL=http://gorse-master:8088
GORSE_API_KEY=secure_random_key_123
GORSE_LOG_LEVEL=debug
# Needed by config.toml's ${GORSE_CACHE_STORE} / ${GORSE_DATA_STORE} substitution.
GORSE_CACHE_STORE=redis://redis:6379/0
GORSE_DATA_STORE=postgresql://postgres:postgres@postgres:5432/betterbundle?sslmode=disable
GORSE_MASTER_HOST=0.0.0.0

# ===========================================
# GOOGLE AI (Gemini / Vertex AI) - Gorse LLM reranking + item embeddings
# ===========================================
AI_PROVIDER=gemini
# Get this from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_dev_gemini_api_key
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMENSIONS=768
AI_CHAT_MODEL=gemini-3.1-flash-lite
# Shared secret between Gorse's reranker_api config and python-worker's /api/v1/ai-rerank endpoint
AI_RERANK_TOKEN=dev_rerank_token_123
# Unused while AI_PROVIDER=gemini
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ===========================================
# SHOPIFY APP CONFIGURATION (Development)
# ===========================================
SHOPIFY_API_KEY=your_dev_shopify_api_key
SHOPIFY_API_SECRET=your_dev_shopify_api_secret
SCOPES=read_custom_pixels,read_customer_data_erasure,read_customer_events,read_customers,read_draft_orders,read_files,read_inventory,read_locations,read_markets,read_metaobject_definitions,read_metaobjects,read_order_edits,read_orders,read_pixels,read_products,read_publications,read_returns,read_themes,write_custom_pixels,write_customer_data_erasure,write_customers,write_draft_orders,write_files,write_inventory,write_locations,write_markets,write_metaobject_definitions,write_metaobjects,write_order_edits,write_orders,write_pixels,write_products,write_publications,write_returns,write_themes
SHOPIFY_APP_URL=https://your-ngrok-url.ngrok.io
SHOPIFY_APP_SESSION_SECRET=dev_session_secret_123
SHOPIFY_APP_HANDLE=better-bundle-dev

# ===========================================
# OBSERVABILITY (OpenObserve)
# ===========================================
# Old Grafana/Loki variables have been removed — OpenObserve is the sole observability backend.
# OpenObserve (new observability platform)
OPENOBSERVE_ENDPOINT=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_API_KEY=
OPENOBSERVE_ADMIN_PASSWORD=admin

# MinIO (S3-compatible storage for OpenObserve)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===========================================
# SECURITY & ENCRYPTION (Development)
# ===========================================
PYTHON_WORKER_API_URL=http://python-worker:8000

JWT_SECRET=dev_jwt_secret_123
ENCRYPTION_KEY=dev_encryption_key_123
