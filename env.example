# ===========================================
# BetterBundle Environment Configuration
# ===========================================
# Copy this file to .env.dev for development or .env.prod for production
# and fill in the appropriate values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
# NODE_ENV=production

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Database URL (auto-generated from above, but can be overridden)
# DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/betterbundle

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
# For development: KAFKA_BOOTSTRAP_SERVERS=kafka_b:9093

# ===========================================
# GORSE RECOMMENDATION ENGINE
# ===========================================
GORSE_BASE_URL=http://gorse-master:8088
GORSE_API_KEY=your_secure_gorse_api_key_here
GORSE_LOG_LEVEL=info
# For development: GORSE_LOG_LEVEL=debug
# Needed by config.toml's ${GORSE_CACHE_STORE} / ${GORSE_DATA_STORE} substitution.
GORSE_CACHE_STORE=redis://redis:6379/0
GORSE_DATA_STORE=postgresql://postgres:postgres@postgres:5432/betterbundle?sslmode=disable
GORSE_MASTER_HOST=0.0.0.0

# ===========================================
# GOOGLE AI (Gemini / Vertex AI) - Gorse LLM reranking + item embeddings
# ===========================================
# "gemini" for staging (AI Studio API key), "vertex" for production (service account)
AI_PROVIDER=gemini
# Get this from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Only used when AI_PROVIDER=vertex
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMENSIONS=768
AI_CHAT_MODEL=gemini-2.0-flash-lite
# Shared secret between Gorse's reranker_api config and python-worker's /api/v1/ai-rerank endpoint
AI_RERANK_TOKEN=your_secure_rerank_token_here

# ===========================================
# SHOPIFY APP CONFIGURATION
# ===========================================
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_APP_URL=https://your-app-domain.com
SHOPIFY_APP_SESSION_SECRET=your_session_secret_here

# ===========================================
# OBSERVABILITY (OpenObserve)
# ===========================================
# Old Grafana/Loki variables have been removed — OpenObserve is the sole observability backend.
# OpenObserve (replaces Grafana/Loki)
OPENOBSERVE_ENDPOINT=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_API_KEY=
OPENOBSERVE_ADMIN_PASSWORD=admin

# MinIO (S3-compatible storage for OpenObserve dev/local)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===========================================
# SECURITY & ENCRYPTION
# ===========================================
# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Encryption key for sensitive data
ENCRYPTION_KEY=your_encryption_key_here

# ===========================================
# PYTHON WORKER
# ===========================================
PYTHON_WORKER_API_URL=http://python-worker:8000

# ===========================================
# EXTERNAL SERVICES (Optional)
# ===========================================
# Email Service (if using email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Analytics (if using external analytics)
# ANALYTICS_API_KEY=your_analytics_key
# ANALYTICS_ENDPOINT=https://analytics.example.com

# ===========================================
# DEVELOPMENT SPECIFIC
# ===========================================
# Uncomment for development
# DEBUG=true
# LOG_LEVEL=debug
# HOT_RELOAD=true

# ===========================================
# PRODUCTION SPECIFIC
# ===========================================
# Uncomment for production
# DEBUG=false
# LOG_LEVEL=info
# HOT_RELOAD=false

# ===========================================
# DOCKER COMPOSE OVERRIDES
# ===========================================
# These can be used to override default compose settings
# COMPOSE_PROJECT_NAME=betterbundle
# COMPOSE_FILE=docker-compose.dev.yml

# ===========================================
# NOTES
# ===========================================
# 1. Never commit actual .env files to version control
# 2. Use strong, unique passwords for production
# 3. Rotate secrets regularly
# 4. Use environment-specific values for dev/prod
# 5. Consider using a secrets management service for production
