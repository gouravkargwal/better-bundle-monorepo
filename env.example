# ===========================================
# BetterBundle Environment Configuration
# ===========================================
# Copy this file to .env.dev for development or .env.prod for production
# and fill in the appropriate values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
# NODE_ENV=production

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Database URL (auto-generated from above, but can be overridden)
# DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/betterbundle

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BROKERS=kafka:9093
# For development: KAFKA_BROKERS=kafka_b:9093

# ===========================================
# TFRS + VERTEX AI (replaces Gorse)
# ===========================================
# Model storage path
TFRS_MODEL_PATH=models/tfrs

# Gemini for product embeddings + recommendations (API-key auth)
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key
# Set to true + use a Vertex AI Express Mode key to switch backends later
GOOGLE_GENAI_USE_VERTEXAI=false
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004
VERTEX_AI_GENERATIVE_MODEL=gemini-2.0-flash-001

# ===========================================
# SHOPIFY APP CONFIGURATION
# ===========================================
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_APP_URL=https://your-app-domain.com
SHOPIFY_APP_SESSION_SECRET=your_session_secret_here

# ===========================================
# MONITORING & LOGGING
# ===========================================
# OpenObserve Configuration (logs, metrics, traces, dashboards)
OPENOBSERVE_URL=http://openobserve:5080
OPENOBSERVE_EMAIL=admin@betterbundle.com
OPENOBSERVE_PASSWORD=your_openobserve_password_here
OPENOBSERVE_ORG_ID=default

# Distributed Tracing (OpenTelemetry -> OpenObserve)
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5080
OTEL_SERVICE_NAME=betterbundle

# ===========================================
# SECURITY & ENCRYPTION
# ===========================================
# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Encryption key for sensitive data
ENCRYPTION_KEY=your_encryption_key_here

# ===========================================
# EXTERNAL SERVICES (Optional)
# ===========================================
# Email Service (if using email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Analytics (if using external analytics)
# ANALYTICS_API_KEY=your_analytics_key
# ANALYTICS_ENDPOINT=https://analytics.example.com

# ===========================================
# DEVELOPMENT SPECIFIC
# ===========================================
# Uncomment for development
# DEBUG=true
# LOG_LEVEL=debug
# HOT_RELOAD=true

# ===========================================
# PRODUCTION SPECIFIC
# ===========================================
# Uncomment for production
# DEBUG=false
# LOG_LEVEL=info
# HOT_RELOAD=false

# ===========================================
# DOCKER COMPOSE OVERRIDES
# ===========================================
# These can be used to override default compose settings
# COMPOSE_PROJECT_NAME=betterbundle
# COMPOSE_FILE=docker-compose.dev.yml

# ===========================================
# NOTES
# ===========================================
# 1. Never commit actual .env files to version control
# 2. Use strong, unique passwords for production
# 3. Rotate secrets regularly
# 4. Use environment-specific values for dev/prod
# 5. Consider using a secrets management service for production
