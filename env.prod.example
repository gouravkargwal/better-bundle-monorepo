# ===========================================
# BetterBundle Production Environment
# ===========================================
# Copy this to .env.prod and update with your production values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=production
DEBUG=false
LOG_LEVEL=info
HOT_RELOAD=false

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=BetterBundle2024!SecureDB

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=BetterBundle2024!SecureRedis
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BROKERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ===========================================
# TFRS + VERTEX AI (replaces Gorse)
# ===========================================
TFRS_MODEL_PATH=models/tfrs
VERTEX_AI_API_KEY=your_vertex_ai_api_key
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004
VERTEX_AI_GENERATIVE_MODEL=gemini-2.0-flash-001

# ===========================================
# SHOPIFY APP CONFIGURATION (Production)
# ===========================================
SHOPIFY_API_KEY=your_prod_shopify_api_key
SHOPIFY_API_SECRET=your_prod_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_APP_URL=https://your-production-domain.com
SHOPIFY_APP_SESSION_SECRET=BetterBundle2024!SessionSecret
SHOPIFY_APP_HANDLE=better-bundle

# ===========================================
# MONITORING & LOGGING
# ===========================================
OPENOBSERVE_URL=http://openobserve:5080
OPENOBSERVE_EMAIL=admin@betterbundle.com
OPENOBSERVE_PASSWORD=BetterBundle2024!OpenObserve
OPENOBSERVE_ORG_ID=default

# Distributed Tracing (OpenTelemetry -> OpenObserve)
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5080
OTEL_SERVICE_NAME=betterbundle

# ===========================================
# SECURITY & ENCRYPTION (Production)
# ===========================================
JWT_SECRET=BetterBundle2024!JWTSecretKey
ENCRYPTION_KEY=BetterBundle2024!EncryptionKey

# ===========================================
# APPLICATION URLS (for internal communication)
# ===========================================
DATABASE_URL=postgresql://postgres:BetterBundle2024!SecureDB@postgres:5432/betterbundle

# ===========================================
# EXTERNAL SERVICES (Production)
# ===========================================
# Email Service
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_production_email@domain.com
# SMTP_PASSWORD=your_smtp_password

# Analytics
# ANALYTICS_API_KEY=your_production_analytics_key
# ANALYTICS_ENDPOINT=https://analytics.your-domain.com

# ===========================================
# PRODUCTION SECURITY NOTES
# ===========================================
# 1. Use strong, unique passwords (minimum 32 characters)
# 2. Rotate secrets regularly (every 90 days)
# 3. Use environment-specific secrets
# 4. Consider using a secrets management service
# 5. Enable audit logging
# 6. Use HTTPS for all external communications
