# ===========================================
# BetterBundle Production Environment
# ===========================================
# Copy this to .env.prod and update with your production values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=production
DEBUG=false
LOG_LEVEL=info
HOT_RELOAD=false

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=betterbundle
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME_WITH_SECURE_PASSWORD

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME_WITH_SECURE_PASSWORD
REDIS_DB=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ===========================================
# GORSE RECOMMENDATION ENGINE
# ===========================================
GORSE_BASE_URL=http://gorse:8088
GORSE_API_KEY=REPLACE_ME_WITH_SECURE_PASSWORD
GORSE_LOG_LEVEL=info
GORSE_CACHE_STORE=redis://redis:6379/0
GORSE_DATA_STORE=postgresql://REPLACE_ME:REPLACE_ME_WITH_SECURE_PASSWORD@postgres:5432/betterbundle?sslmode=disable
GORSE_MASTER_HOST=0.0.0.0

# ===========================================
# GOOGLE AI (Vertex AI) - Gorse LLM reranking + item embeddings
# ===========================================
AI_PROVIDER=vertex
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
# Path inside the container where the service-account JSON is mounted
# (see the python-worker volume mount in docker-compose.prod.yml)
GOOGLE_APPLICATION_CREDENTIALS=/etc/gcp/service-account.json
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMENSIONS=768
AI_CHAT_MODEL=gemini-3.1-flash-lite
# Shared secret between Gorse's reranker_api config and python-worker's /api/v1/ai-rerank endpoint
AI_RERANK_TOKEN=REPLACE_ME_WITH_SECURE_PASSWORD
# Unused while AI_PROVIDER=vertex, kept for parity/rollback to Gemini API key auth
GEMINI_API_KEY=

# ===========================================
# SHOPIFY APP CONFIGURATION (Production)
# ===========================================
SHOPIFY_API_KEY=your_prod_shopify_api_key
SHOPIFY_API_SECRET=your_prod_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_APP_URL=https://your-production-domain.com
SHOPIFY_APP_SESSION_SECRET=REPLACE_ME_WITH_SECURE_PASSWORD
SHOPIFY_APP_HANDLE=better-bundle

# ===========================================
# OBSERVABILITY (OpenObserve)
# ===========================================
# Old Grafana/Loki variables have been removed — OpenObserve is the sole observability backend.
# OpenObserve (new observability platform)
OPENOBSERVE_ENDPOINT=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_API_KEY=
OPENOBSERVE_ADMIN_PASSWORD=REPLACE_ME_WITH_SECURE_PASSWORD

# ===========================================
# SECURITY & ENCRYPTION (Production)
# ===========================================
JWT_SECRET=REPLACE_ME_WITH_SECURE_PASSWORD
ENCRYPTION_KEY=REPLACE_ME_WITH_SECURE_PASSWORD

# ===========================================
# AWS S3 (for OpenObserve production storage)
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ===========================================
# PYTHON WORKER
# ===========================================
PYTHON_WORKER_API_URL=http://python-worker:8000

# ===========================================
# APPLICATION URLS (for internal communication)
# ===========================================
DATABASE_URL=postgresql://REPLACE_ME:REPLACE_ME_WITH_SECURE_PASSWORD@postgres:5432/betterbundle

# ===========================================
# EXTERNAL SERVICES (Production)
# ===========================================
# Email Service
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_production_email@domain.com
# SMTP_PASSWORD=your_smtp_password

# Analytics
# ANALYTICS_API_KEY=your_production_analytics_key
# ANALYTICS_ENDPOINT=https://analytics.your-domain.com

# ===========================================
# PRODUCTION SECURITY NOTES
# ===========================================
# 1. Use strong, unique passwords (minimum 32 characters)
# 2. Rotate secrets regularly (every 90 days)
# 3. Use environment-specific secrets
# 4. Consider using a secrets management service
# 5. Enable audit logging
# 6. Use HTTPS for all external communications
